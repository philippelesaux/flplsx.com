---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from "astro:content";
import { getImage } from "astro:assets";
import PhotoGallery from "../components/PhotoGallery.astro";
import Hero from "../components/Hero.astro";

const portfolio = await getCollection("portfolio");
portfolio.sort(() => Math.random() - 0.5);

const heroEntries = portfolio.slice(0, 5);
const heroImages = await Promise.all(
    heroEntries.map(async (entry) => {
        const image = await getImage({ src: entry.data.image, width: 1400, format: "webp" });
        return { src: image.src, alt: entry.data.alt };
    })
);

const allImages = await Promise.all(
    portfolio.map(async (entry) => {
        const thumbnail = await getImage({ src: entry.data.image, width: 400, format: "webp" });
        const display = await getImage({ src: entry.data.image, width: 1400, format: "webp" });
        return { ...entry.data, thumbnail, display };
    })
);

---
<BaseLayout title="Home">
    <Hero heroImages={heroImages} />
    <div class="gallery">
        <PhotoGallery allImages={allImages} />
    </div>
</BaseLayout>

<style>
    .gallery {
        text-align: center;
        margin-bottom: var(--space-16);
    }
</style>