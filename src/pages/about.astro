---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import headshot from "../data/headshot.jpg";
---

<BaseLayout title="About">
    <div class="about-wrapper">
        <figure>
            <Image
                src={headshot}
                alt="Headshot of Philippe on some steps"
            />
            <figcaption>Photo by <a href="https://www.claywilliamsphoto.com">Clay Williams</a></figcaption>
        </figure>
        <div class="about-content">
            <div class="identity">
                <h1>Philippe LeSaux</h1>
                <p class="roles">Photographer · Software Engineer</p>
            </div>
            <div class="credentials">
                <h2 class="credentials-label">Featured in</h2>
                <ul class="pub-list">
                    <li><span class="pub-icon"></span>Time Out</li>
                    <li><span class="pub-icon"></span>Edible</li>
                    <li><span class="pub-icon"></span>Philly Mag</li>
                </ul>
            </div>
            <p class="bio">I'm a digital artist, jumping mediums from music to code to photography. Specializing in food and travel photography, my work has been featured in Time Out, Edible and Philly Mag. I take too many pictures of my dog, Lenny.</p>
        </div>
    </div>
</BaseLayout>

<style>
    .about-wrapper {
        max-width: 960px;
        margin: 0 auto;
        padding: var(--space-16) var(--space-8) var(--space-16);
        display: grid;
        grid-template-columns: 1fr;
        gap: var(--space-8);
    }

    @media (min-width: 768px) {
        .about-wrapper {
            grid-template-columns: 2fr 3fr;
            align-items: start;
        }
    }

    figure {
        width: 100%;
        margin: 0;
    }

    figure img {
        width: 100%;
        display: block;
    }

    figcaption {
        margin-top: var(--space-2);
        text-align: right;
        font-size: var(--text-sm);
        color: var(--color-text-secondary);
    }

    figcaption a {
        text-decoration: underline;
    }

    .about-content {
        display: flex;
        flex-direction: column;
        gap: var(--space-8);
    }

    .identity {
        display: flex;
        flex-direction: column;
        gap: var(--space-1);
    }

    h1 {
        font-family: var(--font-display);
        font-size: var(--text-3xl);
        font-weight: 400;
        letter-spacing: var(--tracking-wider);
        color: var(--color-text);
        margin: 0;
    }

    @media (min-width: 768px) {
        h1 {
            font-size: var(--text-5xl);
        }
    }

    .bio {
        color: var(--color-text);
        margin: 0;
    }

    .credentials-label {
        font-size: var(--text-sm);
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: var(--tracking-wider);
        color: var(--color-text-muted);
        margin: 0 0 var(--space-2);
    }

    .pub-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: var(--space-2);
    }

    .pub-list li {
        display: flex;
        align-items: center;
        gap: var(--space-2);
        color: var(--color-text-secondary);
    }

    .pub-icon {
        display: inline-block;
        width: 0;
        height: 0;
    }

    .roles {
        font-size: var(--text-sm);
        color: var(--color-text-secondary);
        letter-spacing: var(--tracking-wide);
        margin: 0;
    }
</style>
