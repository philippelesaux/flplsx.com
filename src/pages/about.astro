---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import headshot from "../data/headshot.jpg";
---

<BaseLayout title="About">
    <div class="about-wrapper">
        <div class="about-header">
            <h1>Philippe LeSaux</h1>
            <h2><a href="/">Photographer</a>, Software Engineer, Musician</h2>
        </div>
        <figure>
            <Image
                src={headshot}
                alt="Headshot of Philippe on some steps"
            />
            <figcaption>Photo by <a href="https://www.claywilliamsphoto.com">Clay Williams</a></figcaption>
        </figure>
        <p>Philippe is a digital artist, jumping mediums from music to code to photography. Specializing in food and travel photography, his work has been featured in Time Out, Edible and Philly Mag. He takes too many pictures of his dog, Lenny.</p>
    </div>
</BaseLayout>

<style>
    .about-wrapper {
        margin: 0 var(--space-8);
    }

    .about-header {
        margin: var(--space-8) 0;
    }

    h1 {
        margin: var(--space-4) 0;
        text-align: center;
        font-size: var(--text-5xl);
        color: var(--color-accent);
        letter-spacing: var(--tracking-wider);
        font-family: 'Fraunces Variable', serif;
        font-weight: 400;
    }

    h2 {
        padding: 0 var(--space-4);
        text-align: center;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: var(--tracking-wider);
        color: var(--color-text-secondary);
    }

    figure {
        width: 50%;
        margin: var(--space-8) auto;
    }

    @media (min-width: 768px) {
        figure {
            width: 33.333%;
        }
    }

    figcaption {
        text-align: right;
        font-size: var(--text-sm);
        color: var(--color-text-secondary);
    }

    figcaption a {
        text-decoration: underline;
    }

    p {
        color: var(--color-text-secondary);
    }
</style>
