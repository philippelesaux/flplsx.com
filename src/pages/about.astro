---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import headshot from "../data/headshot.jpg";
---

<BaseLayout title="About">
    <div class="about-wrapper">
        <figure>
            <Image
                src={headshot}
                alt="Headshot of Philippe on some steps"
            />
            <figcaption>Photo by <a href="https://www.claywilliamsphoto.com">Clay Williams</a></figcaption>
        </figure>
        <div class="about-content">
            <div class="identity">
                <h1>Philippe LeSaux</h1>
                <p class="roles">Photographer · Software Engineer</p>
            </div>
            <div class="credentials">
                <h2 class="credentials-label">Featured in</h2>
                <ul class="pub-list">
                    <li><a href="https://www.timeout.com/miami/hotels/the-vagabond-hotel" target="_blank">Time Out</a></li>
                    <li><a href="https://ediblephilly.ediblecommunities.com/drink/pennsylvania-the-finger-lakes/" target="_blank">Edible Philly Magazine</a></li>
                    <li><a href="https://gridphilly.com/blog-home/2026/04/04/longwood-gardens-ornamental-kitchen-garden-features-a-seed-to-table-dining-experience/" target="_blank">Grid Magazine</a></li>
                    <li><a href="https://www.phillymag.com/news/great-bars-pubs-neighborhood-guide/" target="_blank">Philadelphia Magazine</a></li>
                </ul>
            </div>
            <p class="bio">I'm a digital artist, jumping mediums from photography to code to music. Specializing in food and travel photography, my work has been featured in Time Out, Edible Philly Magazine, Grid Magazine and Philadelphia Magazine, in both digital and physical media. I take too many pictures of my dog, Lenny.</p>
            <div class="contact" data-contact>
                <h2 class="contact-label">Contact</h2>
                <ul class="contact-list">
                    <li class="contact-row">
                        <svg class="contact-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                            <circle cx="12" cy="12" r="4"/>
                            <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"/>
                        </svg>
                        <a href="https://www.instagram.com/flplsx/" target="_blank" rel="noopener noreferrer" class="contact-link">@flplsx</a>
                    </li>
                    <li class="contact-row">
                        <svg class="contact-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <rect x="2" y="4" width="20" height="16" rx="2"/>
                            <polyline points="2,4 12,13 22,4"/>
                        </svg>
                        <span class="contact-email">photography@flplsx.com</span>
                        <button class="copy-btn" data-copy-email aria-label="Copy email address" title="Copy email">
                            <svg class="copy-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <rect x="9" y="9" width="13" height="13" rx="2"/>
                                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                            </svg>
                            <svg class="check-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <polyline points="20 6 9 17 4 12"/>
                            </svg>
                        </button>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</BaseLayout>

<script>
    import { initContact } from '../scripts/contact';
    initContact(document.querySelector('[data-contact]')!);
</script>

<style>
    .about-wrapper {
        max-width: 960px;
        margin: 0 auto;
        padding: var(--space-16) var(--space-8) var(--space-16);
        display: grid;
        grid-template-columns: 1fr;
        gap: var(--space-8);
    }

    @media (min-width: 768px) {
        .about-wrapper {
            grid-template-columns: 2fr 3fr;
            align-items: start;
        }
    }

    figure {
        width: 100%;
        margin: 0;
    }

    figure img {
        width: 100%;
        display: block;
    }

    figcaption {
        margin-top: var(--space-2);
        text-align: right;
        font-size: var(--text-sm);
        color: var(--color-text-secondary);
    }

    figcaption a {
        text-decoration: underline;
    }

    .about-content {
        display: flex;
        flex-direction: column;
        gap: var(--space-8);
    }

    .identity {
        display: flex;
        flex-direction: column;
        gap: var(--space-1);
    }

    h1 {
        font-family: var(--font-display);
        font-size: var(--text-3xl);
        font-weight: 400;
        letter-spacing: var(--tracking-wider);
        color: var(--color-text);
        margin: 0;
    }

    @media (min-width: 768px) {
        h1 {
            font-size: var(--text-5xl);
        }
    }

    .bio {
        color: var(--color-text);
        margin: 0;
    }

    .credentials-label {
        font-size: var(--text-sm);
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: var(--tracking-wider);
        color: var(--color-text-muted);
        margin: 0 0 var(--space-2);
    }

    .pub-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: var(--space-2);
    }

    .pub-list li {
        display: flex;
        align-items: center;
        gap: var(--space-2);
        color: var(--color-text-secondary);
    }

    .pub-icon {
        display: inline-block;
        width: 0;
        height: 0;
    }

    .roles {
        font-size: var(--text-sm);
        color: var(--color-text-secondary);
        letter-spacing: var(--tracking-wide);
        margin: 0;
    }

    .contact-label {
        font-size: var(--text-sm);
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: var(--tracking-wider);
        color: var(--color-text-muted);
        margin: 0 0 var(--space-2);
    }

    .contact-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: var(--space-2);
    }

    .contact-row {
        display: flex;
        align-items: center;
        gap: var(--space-2);
    }

    .contact-icon {
        width: 1.25rem;
        height: 1.25rem;
        flex-shrink: 0;
        color: var(--color-text-secondary);
        align-self: center;
    }

    .contact-link,
    .contact-email {
        font-size: var(--text-base);
        color: var(--color-text);
    }

    .contact-link {
        text-decoration: none;
    }

    .contact-link:hover {
        text-decoration: underline;
    }

    .copy-btn {
        display: inline-grid;
        align-items: center;
        background: none;
        border: none;
        padding: 0;
        cursor: pointer;
        color: var(--color-text-secondary);
        line-height: 0;
    }

    .copy-icon,
    .check-icon {
        grid-area: 1 / 1;
        width: 0.875rem;
        height: 0.875rem;
    }

    /* Default: copy visible, check hidden — fade in when data-copied is removed */
    .copy-icon {
        opacity: 1;
        transition: opacity 0.3s ease;
    }

    .check-icon {
        opacity: 0;
        color: var(--color-accent);
        transition: opacity 0.3s ease;
    }

    /* Copied state: swap instantly (transition: none), no animation on entry */
    .copy-btn[data-copied] .copy-icon {
        opacity: 0;
        transition: none;
    }

    .copy-btn[data-copied] .check-icon {
        opacity: 1;
        transition: none;
    }
</style>
