---
interface HeroImage {
    src: string;
    alt: string;
}

interface Props {
    heroImages: HeroImage[];
}

const { heroImages } = Astro.props;
---

<div data-hero>
    {heroImages.map((image) => (
        <img src={image.src} alt={image.alt} class="image" />
    ))}
    <div class="gradient" />
</div>

<style>
    [data-hero] {
        height: 100vh;
        width: 100%;
        position: relative;
        overflow: hidden;
    }

    .image {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: 0;
        transition: opacity 1000ms ease;
    }

    .image.active {
        opacity: 1;
    }

    .gradient {
        position: absolute;
        left: 0;
        right: 0;
        top: 0;
        height: 12rem;
        background-image: linear-gradient(to bottom, rgb(0 0 0 / 0.6), transparent);
        pointer-events: none;
        z-index: 10;
    }
</style>

<script>
    import { initHero } from '../scripts/hero';
    initHero(document.querySelector<HTMLElement>('[data-hero]')!);
</script>
