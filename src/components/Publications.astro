---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const entries = await getCollection('press');
---

<section class="publications">
    <h2 class="publications-label">Recent Publications</h2>
    <div class="publications-grid">
        {entries.map((entry) => (
            <div class="pub-card">
                <a
                    class="pub-image-link"
                    href={entry.data.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    tabindex="-1"
                    aria-hidden="true"
                >
                    <Image
                        src={entry.data.image}
                        alt={entry.data.alt}
                        width={680}
                    />
                </a>
                <div class="pub-card-text">
                    <a
                        class="pub-article-link"
                        href={entry.data.url}
                        target="_blank"
                        rel="noopener noreferrer"
                    >
                        <p class="pub-name">{entry.data.publication}</p>
                        <p class="pub-title">{entry.data.articleTitle}</p>
                    </a>
                    <p class="pub-author">
                        by {entry.data.authorUrl
                            ? <a href={entry.data.authorUrl} target="_blank" rel="noopener noreferrer" class="pub-author-link">{entry.data.author}</a>
                            : entry.data.author
                        }
                    </p>
                </div>
            </div>
        ))}
    </div>
</section>

<style>
    .publications {
        max-width: 720px;
        margin: 0 auto;
        padding: var(--space-16) var(--space-8);
    }

    .publications-label {
        font-size: var(--text-lg);
        font-weight: 400;
        text-transform: uppercase;
        letter-spacing: var(--tracking-wider);
        color: var(--color-text-secondary);
        margin: 0 0 var(--space-8);
    }

    .publications-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: var(--space-8);
    }

    @media (min-width: 600px) {
        .publications-grid {
            grid-template-columns: 1fr 1fr;
        }
    }

    .pub-card {
        display: flex;
        flex-direction: column;
        gap: 0;
    }

    .pub-image-link {
        display: block;
        overflow: hidden;
    }

    .pub-image-link img {
        width: 100%;
        display: block;
        aspect-ratio: 4 / 3;
        object-fit: cover;
        transition: transform 200ms ease;
        clip-path: inset(0);
    }

    .pub-image-link:hover img {
        transform: scale(1.03);
    }

    .pub-card-text {
        padding: var(--space-2) 0;
        display: flex;
        flex-direction: column;
        gap: var(--space-1);
    }

    .pub-article-link {
        text-decoration: none;
        color: inherit;
    }

    .pub-article-link:hover .pub-title {
        text-decoration: underline;
    }

    .pub-name {
        font-size: var(--text-sm);
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: var(--tracking-wider);
        color: var(--color-text-muted);
        margin: 0;
    }

    .pub-title {
        color: var(--color-text);
        margin: 0;
    }

    .pub-author {
        font-size: var(--text-sm);
        color: var(--color-text-secondary);
        margin: 0;
    }

    .pub-author-link {
        color: inherit;
        text-decoration: none;
    }

    .pub-author-link:hover {
        text-decoration: underline;
    }
</style>
