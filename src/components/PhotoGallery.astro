---
interface GalleryImage {
    thumbnail: { src: string };
    display: { src: string };
    title: string;
    location: string;
    alt: string;
}

interface Props {
    allImages: GalleryImage[];
}

const { allImages } = Astro.props;
---

<div class="gallery-grid">
    {allImages.map((image) => (
        <button
            class="thumb-btn"
            data-display={image.display.src}
            data-title={image.title}
            data-location={image.location}
            data-alt={image.alt}
            aria-label={`View ${image.title}, ${image.location}`}
        >
            <img
                src={image.thumbnail.src}
                alt={image.alt}
                width={400}
                class="thumb-img"
                loading="lazy"
            />
        </button>
    ))}
</div>

<dialog class="photo-dialog" aria-label="Photo viewer">
    <button class="dialog-close" data-close aria-label="Close photo viewer">&#10005;</button>
    <img class="dialog-img" src="" alt="" />
    <div class="dialog-strip">
        <div class="dialog-meta" aria-live="polite">
            <span class="dialog-title"></span>
            <span class="dialog-location"></span>
        </div>
    </div>
    <button class="sr-only" data-prev aria-label="Previous photo">Previous</button>
    <button class="sr-only" data-next aria-label="Next photo">Next</button>
</dialog>

<style>
    :global(:root) {
        --photo-transition-duration: 300ms;
    }

    :global(::view-transition-group(active-photo)) {
        animation-duration: var(--photo-transition-duration);
    }

    /* Grid */
    .gallery-grid {
        padding: var(--space-2);
        margin: var(--space-8) auto;
        max-width: 1536px;
        columns: 2;
        gap: var(--space-4);
    }

    @media (min-width: 768px) { .gallery-grid { columns: 3; } }
    @media (min-width: 1024px) { .gallery-grid { columns: 4; } }
    @media (min-width: 1280px) { .gallery-grid { columns: 5; } }

    /* Thumbnail button */
    .thumb-btn {
        display: block;
        width: 100%;
        padding: 0;
        margin: 0;
        margin-bottom: var(--space-4);
        background: none;
        border: none;
        cursor: pointer;
        break-inside: avoid;
    }

    /* Thumbnail image */
    .thumb-img {
        display: block;
        width: 100%;
        clip-path: inset(0);
        opacity: 0;
        transform: translateY(1rem);
        transition: opacity 500ms ease-in-out, transform 200ms ease-out;
    }

    .thumb-img.visible {
        opacity: 1;
        transform: translateY(0);
    }

    .thumb-img.visible:hover {
        transform: scale(1.03);
    }

    /* Dialog */
    .photo-dialog {
        width: 100vw;
        height: 100dvh;
        max-width: 100%;
        max-height: 100%;
        margin: 0;
        padding: 0;
        border: none;
        background: transparent;
    }

    .photo-dialog[open] {
        display: flex;
        flex-direction: column;
    }

    .photo-dialog::backdrop {
        backdrop-filter: blur(20px);
        background: rgb(0 0 0 / 0.6);
        transition:
            backdrop-filter var(--photo-transition-duration) ease,
            background var(--photo-transition-duration) ease;
    }

    @starting-style {
        .photo-dialog[open]::backdrop {
            backdrop-filter: blur(0px);
            background: rgb(0 0 0 / 0);
        }
    }

    /* Close button */
    .dialog-close {
        position: absolute;
        top: var(--space-4);
        right: var(--space-4);
        z-index: 1;
        background: none;
        border: none;
        color: white;
        cursor: pointer;
        font-size: var(--text-xl);
        width: 44px;
        height: 44px;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0.8;
        transition: opacity 150ms ease;
    }

    .dialog-close:hover {
        opacity: 1;
    }

    .dialog-img {
        flex: 1;
        width: 100%;
        min-height: 0;
        object-fit: contain;
    }

    /* Metadata strip */
    .dialog-strip {
        padding: var(--space-3) var(--space-4);
        background: rgb(0 0 0 / 0.4);
        color: white;
        flex-shrink: 0;
    }

    .dialog-meta {
        display: flex;
        flex-direction: column;
        gap: 0.125rem;
        min-width: 0;
    }

    .dialog-title {
        font-size: var(--text-sm);
        font-weight: 400;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .dialog-location {
        font-size: var(--text-sm);
        color: rgb(255 255 255 / 0.6);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
    }
</style>

<script>
    import { initGallery } from '../scripts/gallery';
    const grid = document.querySelector<HTMLElement>('.gallery-grid')!;
    const dialog = document.querySelector<HTMLDialogElement>('.photo-dialog')!;
    initGallery(grid, dialog);
</script>
