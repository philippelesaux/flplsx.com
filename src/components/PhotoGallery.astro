---
interface GalleryImage {
    thumbnail: { src: string };
    display: { src: string };
    title: string;
    location: string;
    alt: string;
}

interface Props {
    allImages: GalleryImage[];
}

const { allImages } = Astro.props;
---

<div class="gallery-grid">
    {allImages.map((image) => (
        <button
            class="thumb-btn"
            data-display={image.display.src}
            data-title={image.title}
            data-location={image.location}
            data-alt={image.alt}
            aria-label={`View ${image.title}, ${image.location}`}
        >
            <img
                src={image.thumbnail.src}
                alt={image.alt}
                width={400}
                class="thumb-img"
                loading="lazy"
            />
        </button>
    ))}
</div>

<dialog class="photo-dialog" aria-label="Photo viewer">
    <img class="dialog-img" src="" alt="" />
    <div class="dialog-bar">
        <div class="dialog-meta">
            <span class="dialog-title"></span>
            <span class="dialog-location"></span>
        </div>
        <div class="dialog-controls">
            <button class="dialog-btn" data-prev aria-label="Previous photo">&#8592;</button>
            <button class="dialog-btn" data-close aria-label="Close photo viewer">&#10005;</button>
            <button class="dialog-btn" data-next aria-label="Next photo">&#8594;</button>
        </div>
    </div>
</dialog>

<style>
    /* Grid */
    .gallery-grid {
        padding: var(--space-2);
        margin: var(--space-8) auto;
        max-width: 1536px;
        columns: 2;
        gap: var(--space-4);
    }

    @media (min-width: 768px) { .gallery-grid { columns: 3; } }
    @media (min-width: 1024px) { .gallery-grid { columns: 4; } }
    @media (min-width: 1280px) { .gallery-grid { columns: 5; } }

    /* Thumbnail button */
    .thumb-btn {
        display: block;
        width: 100%;
        padding: 0;
        margin: 0;
        margin-bottom: var(--space-4);
        background: none;
        border: none;
        cursor: pointer;
        break-inside: avoid;
    }

    /* Thumbnail image */
    .thumb-img {
        display: block;
        width: 100%;
        clip-path: inset(0);
        opacity: 0;
        transform: translateY(1rem);
        transition: opacity 500ms ease-in-out, transform 200ms ease-out;
    }

    .thumb-img.visible {
        opacity: 1;
        transform: translateY(0);
    }

    .thumb-img.visible:hover {
        transform: scale(1.03);
    }

    /* Dialog */
    .photo-dialog {
        width: 100vw;
        height: 100dvh;
        max-width: 100%;
        max-height: 100%;
        margin: 0;
        padding: 0;
        border: none;
        background: #000;
    }

    .photo-dialog[open] {
        display: flex;
        flex-direction: column;
    }

    .photo-dialog::backdrop {
        background: rgb(0 0 0 / 0.9);
    }

    .dialog-img {
        flex: 1;
        width: 100%;
        min-height: 0;
        object-fit: contain;
    }

    .dialog-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: var(--space-4);
        padding: var(--space-2) var(--space-4);
        background: rgb(0 0 0 / 0.6);
        color: white;
        flex-shrink: 0;
    }

    .dialog-meta {
        display: flex;
        flex-direction: column;
        gap: 0.125rem;
        min-width: 0;
    }

    .dialog-title {
        font-size: var(--text-sm);
        font-weight: 600;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .dialog-location {
        font-size: var(--text-sm);
        color: rgb(255 255 255 / 0.6);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .dialog-controls {
        display: flex;
        align-items: center;
        gap: var(--space-2);
        flex-shrink: 0;
    }

    .dialog-btn {
        background: none;
        border: none;
        color: white;
        cursor: pointer;
        font-size: var(--text-xl);
        padding: var(--space-1) var(--space-2);
        opacity: 0.8;
        transition: opacity 150ms ease;
    }

    .dialog-btn:hover {
        opacity: 1;
    }
</style>

<script>
    import { initGallery } from '../scripts/gallery';
    const grid = document.querySelector<HTMLElement>('.gallery-grid')!;
    const dialog = document.querySelector<HTMLDialogElement>('.photo-dialog')!;
    initGallery(grid, dialog);
</script>
